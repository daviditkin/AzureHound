{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.26.54.24096",
      "templateHash": "15999594271314721416"
    }
  },
  "parameters": {
    "name": {
      "type": "string",
      "defaultValue": "azurehound-group",
      "metadata": {
        "description": "Name for the container group"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "image": {
      "type": "string",
      "defaultValue": "ghcr.io/bloodhoundad/azurehound:latest",
      "metadata": {
        "description": "Container image to deploy. Should be of the form repoName/imagename:tag for images stored in public Docker Hub, or a fully qualified URI for other registries. Images from private registries require additional registry credentials."
      }
    },
    "port": {
      "type": "int",
      "defaultValue": 80,
      "metadata": {
        "description": "Port to open on the container and the public IP address."
      }
    },
    "azurehoundTenant": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "The directory (tenant) that you want to request permission from."
      }
    },
    "azurehoundApp": {
      "type": "securestring",
      "metadata": {
        "description": "The Application (client) Id that the Azure app registration portal assigned when the app was registered."
      }
    },
    "azurehoundCertValue": {
      "type": "securestring",
      "metadata": {
        "description": "The contents of the cert uploaded to the app registration portal."
      }
    },
    "azurehoundKeyValue": {
      "type": "securestring",
      "metadata": {
        "description": "The contents of the key file for a certificate uploaded to the app registration portal."
      }
    },
    "azurehoundKeypass": {
      "type": "securestring",
      "metadata": {
        "description": "The key pass for the certificate if used."
      }
    },
    "azurehoundInstance": {
      "type": "string",
      "defaultValue": "https://demo.bloodhoundenterprise.io",
      "metadata": {
        "description": "The BloodHound Enterprise instance URL."
      }
    },
    "azurehoundTokenId": {
      "type": "securestring",
      "metadata": {
        "description": "The BloodHound Enterprise token ID."
      }
    },
    "azurehoundToken": {
      "type": "securestring",
      "metadata": {
        "description": "The BloodHound Enterprise token."
      }
    },
    "cpuCores": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "The number of CPU cores to allocate to the container."
      }
    },
    "memoryInGb": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "The amount of memory to allocate to the container in gigabytes."
      }
    },
    "restartPolicy": {
      "type": "string",
      "defaultValue": "Always",
      "allowedValues": [
        "Always",
        "Never",
        "OnFailure"
      ],
      "metadata": {
        "description": "The behavior of Azure runtime if container has stopped."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "properties": {
        "containers": [
          {
            "name": "[parameters('name')]",
            "properties": {
              "image": "[parameters('image')]",
              "ports": [
                {
                  "port": "[parameters('port')]",
                  "protocol": "TCP"
                }
              ],
              "command": [
                "/azurehound",
                "list"
              ],
              "volumeMounts": [
                {
                  "name": "config-volume",
                  "mountPath": "/etc/azurehound"
                }
              ],
              "environmentVariables": [
                {
                  "name": "AZUREHOUND_TENANT",
                  "value": "[parameters('azurehoundTenant')]"
                },
                {
                  "name": "AZUREHOUND_APP",
                  "value": "[parameters('azurehoundApp')]"
                },
                {
                  "name": "AZUREHOUND_CERT",
                  "value": "/etc/azurehound/tls.cert"
                },
                {
                  "name": "AZUREHOUND_KEY",
                  "value": "/etc/azurehound/tls.key"
                },
                {
                  "name": "AZUREHOUND_KEYPASS",
                  "value": "[parameters('azurehoundKeypass')]"
                },
                {
                  "name": "AZUREHOUND_INSTANCE",
                  "value": "[parameters('azurehoundInstance')]"
                },
                {
                  "name": "AZUREHOUND_TOKENID",
                  "secureValue": "[parameters('azurehoundTokenId')]"
                },
                {
                  "name": "AZUREHOUND_TOKEN",
                  "secureValue": "[parameters('azurehoundToken')]"
                },
                {
                  "name": "AZUREHOUND_JSON",
                  "value": true
                },
                {
                  "name": "AZUREHOUND_VERBOSITY",
                  "value": 0
                }
              ],
              "resources": {
                "requests": {
                  "cpu": "[parameters('cpuCores')]",
                  "memoryInGB": "[parameters('memoryInGb')]"
                }
              }
            }
          }
        ],
        "osType": "Linux",
        "restartPolicy": "[parameters('restartPolicy')]",
        "volumes": [
          {
            "name": "config-volume",
            "secret": {
              "tls.key": "[parameters('azurehoundKeyValue')]",
              "tls.cert": "[parameters('azurehoundCertValue')]"
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "name": {
      "type": "string",
      "value": "[parameters('name')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "resourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('name'))]"
    },
    "location": {
      "type": "string",
      "value": "[parameters('location')]"
    }
  }
}